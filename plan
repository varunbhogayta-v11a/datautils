    filter: "active=true"
    select: "name,email,role"
    auth: true
  /api/sales:
    source: ./data/sales.json
    transform:
      add: "region=APAC"
    filter: "amount > 1000"
    auth: false
  /api/products:
    source: ./data/products.xlsx
    cache: true
    ttl: 300  # seconds

func startServer() {
    // Create Fiber app
    app := fiber.New(fiber.Config{
        ErrorHandler: customErrorHandler,
        AppName:      "datautil",
    })
    // Middleware
    app.Use(recovery.New())
    app.Use(logger.New())
    app.Use(cors.New())
    // Static routes from config
    routes, _ := LoadRoutes("./configs/routes.yaml")
    registerCustomRoutes(app, routes)
    // API routes
    api := app.Group("/api")

    // Auth (no auth required)
    api.Post("/auth/register", handleAPIRegister)
    api.Post("/auth/login", handleAPILogin)
    // Protected routes
    protected := api.Group("", jwtMiddleware)
    protected.Post("/data/filter", handleAPIFilter)
    // ... other protected routes
    // Health check (no auth)
    app.Get("/api/health", handleHealth)
    // Swagger
    app.Get("/swagger.yaml", serveSwaggerSpec)
    app.Get("/swagger/*", serveSwaggerUI)
    // Start server
    app.Listen(":" + serverPort)
}

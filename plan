func startServer() {
    app := fiber.New(fiber.Config{
        ErrorHandler: customErrorHandler,
        AppName:      "datautil",
    })
    // Global middleware
    app.Use(recovery.New())
    app.Use(logger.New())
    app.Use(cors.New())
    // Load dynamic routes from DB
    routeManager, _ := repo.LoadRoutesFromDB()
    // Register custom routes
    for _, route := range routeManager.Routes {
        registerDynamicRoute(app, route)
    }
    // API Groups
    api := app.Group("/api")
    // Public routes
    api.Post("/auth/register", handleAPIRegister)
    api.Post("/auth/login", handleAPILogin)
    api.Get("/health", handleHealth)
    // Protected routes
    protected := api.Group("", jwtMiddleware)
    protected.Post("/data/filter", handleAPIFilter)
    protected.Post("/data/transform", handleAPITransform)
    protected.Post("/data/validate", handleAPIValidate)
    protected.Post("/data/export", handleAPIExport)
    protected.Post("/data/import", handleAPIImport)
    protected.Post("/db/query", handleAPIQuery)
    protected.Post("/db/insert", handleAPIInsert)
    protected.Post("/db/update", handleAPIUpdate)
    protected.Post("/db/delete", handleAPIDelete)
    protected.Get("/users", handleAPIUsers)
    protected.Get("/logs", handleAPILogs)
    // Admin routes for route management
    admin := protected.Group("/admin")
    admin.Post("/routes", createRoute)
    admin.Put("/routes/:id", updateRoute)

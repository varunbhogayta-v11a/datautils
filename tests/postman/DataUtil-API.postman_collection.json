{
  "info": {
    "name": "DataUtil API",
    "description": "API for dataset processing, filtering, transformation, validation, and database operations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "path": ["api", "health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "path": ["api", "auth", "register"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"test123\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "path": ["api", "auth", "login"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"test123\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Data Operations",
      "item": [
        {
          "name": "Filter Data",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/data/filter",
              "path": ["api", "data", "filter"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"input\": \"tests/test_data.csv\",\n  \"where\": \"age > 25\",\n  \"select\": \"name,age\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Transform Data",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/data/transform",
              "path": ["api", "data", "transform"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"input\": \"tests/test_data.csv\",\n  \"add\": \"fullname=first+last\",\n  \"remove\": \"email\",\n  \"output\": \"output.csv\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Validate Data",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/data/validate",
              "path": ["api", "data", "validate"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"input\": \"tests/test_data.csv\",\n  \"required\": \"name,age\",\n  \"types\": \"age:integer\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Export Data",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/data/export",
              "path": ["api", "data", "export"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"input\": \"tests/test_data.csv\",\n  \"to\": \"json\",\n  \"output\": \"output.json\",\n  \"stats\": true\n}"
            }
          },
          "response": []
        },
        {
          "name": "Import to DB",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/data/import",
              "path": ["api", "data", "import"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"tests/test_data.csv\",\n  \"table\": \"test_data\",\n  \"create\": true\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Database",
      "item": [
        {
          "name": "Query",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/db/query",
              "path": ["api", "db", "query"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sql\": \"SELECT * FROM users LIMIT 10\",\n  \"limit\": 5\n}"
            }
          },
          "response": []
        },
        {
          "name": "Insert",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/db/insert",
              "path": ["api", "db", "insert"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table\": \"users\",\n  \"values\": \"username=newuser,email=new@test.com\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Update",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/db/update",
              "path": ["api", "db", "update"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table\": \"users\",\n  \"set\": \"active = 1\",\n  \"WHERE\": \"username = 'newuser'\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/db/delete",
              "path": ["api", "db", "delete"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table\": \"users\",\n  \"WHERE\": \"username = 'newuser'\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "path": ["api", "users"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "response": []
        },
        {
          "name": "Get Logs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/logs",
              "path": ["api", "logs"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "response": []
        }
      ]
    },
    {
      "name": "Swagger",
      "item": [
        {
          "name": "OpenAPI JSON",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/swagger.json",
              "path": ["swagger.json"]
            }
          },
          "response": []
        },
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/swagger",
              "path": ["swagger"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}